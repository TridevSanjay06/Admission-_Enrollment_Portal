# Dev: leave empty to use Vite proxy (same-origin /api and /Images -> Express).
VITE_API_BASE_URL=
VITE_ASSET_BASE_URL=

# Optional: full URL if UI is hosted separately from the API
# VITE_API_BASE_URL=https://your-api.example.com
# VITE_ASSET_BASE_URL=https://your-api.example.com

# Vite dev proxy target (see vite.config.js)
VITE_DEV_PROXY_TARGET=http://localhost:3000
