# ── Frontend Environment Variables (Vercel) ───────────────────────────────────
# Copy this file to .env.local for local development (Vite loads .env.local first).
# In production, set these in the Vercel dashboard → Settings → Environment Variables.
# NEVER commit your actual .env.local to Git.
# ─────────────────────────────────────────────────────────────────────────────

# Backend API base URL.
# Dev: leave empty — Vite proxy will forward /api/* to localhost:3000 automatically.
# Production: set to your Render backend URL, e.g. https://ams-backend.onrender.com
VITE_API_BASE_URL=

# Static asset base URL (Images served by Express).
# Dev: leave empty (same as above, handled by proxy).
# Production: same as VITE_API_BASE_URL.
VITE_ASSET_BASE_URL=

# Vite dev-only proxy target — points to local Express server.
# Never needs to change unless you run the backend on a different port.
VITE_DEV_PROXY_TARGET=http://localhost:3000
