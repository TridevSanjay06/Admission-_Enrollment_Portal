PORT=3000
NODE_ENV=development

# --- Email (SendGrid OR SMTP) ---

# Option A: SendGrid
SENDGRID_API_KEY=

# Option B: SMTP (e.g. Gmail app password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Legacy aliases (optional)
GMAIL_USER=
GMAIL_PASSWORD=

# "From" address — must match verified sender (SendGrid) or Gmail account
EMAIL_FROM=

# Staff inbox(es) for new applications (comma-separated)
ENROLLMENT_NOTIFY_EMAIL=

# If set, also used as notify recipient when ENROLLMENT_NOTIFY_EMAIL is empty
SCHOOL_FROM_EMAIL=

# Set to "true" to send a short confirmation to the parent email as well
PARENT_ENROLLMENT_COPY=false
