# ── Backend Environment Variables (Render) ────────────────────────────────────
# Copy this file to .env for local development.
# In production, set these in the Render dashboard → Environment tab.
# NEVER commit your actual .env file to Git.
# ─────────────────────────────────────────────────────────────────────────────

PORT=3000
NODE_ENV=development          # Set to "production" on Render

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Example (production): https://ams-frontend.vercel.app
# Leave empty in development — localhost origins are allowed automatically.
ALLOWED_ORIGINS=

# ── SMTP (Gmail recommended) ──────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false

# Your Gmail address
SMTP_USER=

# Gmail App Password (16 chars, no spaces)
# Generate one at: https://myaccount.google.com/apppasswords
SMTP_PASS=

# "From" address shown on sent emails — must match SMTP_USER for Gmail
SCHOOL_FROM_EMAIL=

# Staff inbox that receives new application alerts
ENROLLMENT_NOTIFY_EMAIL=

# Set to "true" to also send a confirmation copy to the parent
PARENT_ENROLLMENT_COPY=true
